[Unit]
Description=pwiki vault Git sync (host-side)

[Service]
Type=oneshot
# A system unit runs as root by default, which usually does NOT have the ~/.ssh
# keys needed for an SSH Git remote. Set User=/Group= to the account that owns
# the vault checkout and can reach the remote. (Prefer the --user units in
# user-pwiki-vault-sync.*.example, which run as your login user automatically.)
#User=youruser
#Group=youruser
# Adjust these paths if the repository is not at /srv/newwiki. EnvironmentFile
# supplies PWIKI_GIT_HOST_DIR (and PWIKI_GIT_HOST_PUSH) from the deployment .env.
WorkingDirectory=/srv/newwiki
EnvironmentFile=/srv/newwiki/.env
# Host-side vault sync (NOT inside the container): the container image ships
# without an SSH client or keys. The script is pull-only by default and switches
# to bidirectional (commit local web writes, rebase, push) when
# PWIKI_GIT_HOST_PUSH=1 is set in .env. PWIKI_GIT_HOST_DIR must be an absolute
# path to the vault Git working tree.
ExecStart=/bin/sh -lc '/srv/newwiki/deploy/pwiki-vault-sync.sh'
